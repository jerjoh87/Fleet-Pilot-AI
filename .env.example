NEXT_PUBLIC_APP_URL=http://localhost:3000
# Platform root domain — tenant sites are served at <slug>.<root> (e.g. luxedrive.fleetpilot.ai)
NEXT_PUBLIC_ROOT_DOMAIN=fleetpilot.ai

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VEHICLE_IMAGES_BUCKET=vehicle-images

# Database (Prisma — use the Supabase pooled connection string for DATABASE_URL)
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription Price IDs (create recurring prices in the Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=

# AI workspace (optional — heuristics run without it, OpenAI enriches narratives)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email (optional — emails are logged to console without this)
RESEND_API_KEY=
EMAIL_FROM=FleetPilot AI <noreply@fleetpilot.ai>
