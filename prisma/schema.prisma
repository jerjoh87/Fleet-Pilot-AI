generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  EMPLOYEE
  CUSTOMER
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  RENTED
  CLEANING
  MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum ReservationStatus {
  QUOTE
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  LATE
  CANCELLED
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  domain      String?  @unique
  stripeCustomerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     Membership[]
  vehicles    Vehicle[]
  customers   Customer[]
  reservations Reservation[]
  websiteSettings WebsiteSetting?
  subscription Subscription?
  bankAccounts BankAccount[]
  payouts     Payout[]
  transactions Transaction[]
  rentalAgreements RentalAgreement[]
  agreementTemplates AgreementTemplate[]
  agreementVersions AgreementVersion[]
  signatureLogs SignatureLog[]
  activityLogs ActivityLog[]
  auditLogs    AuditLog[]
}

model User {
  id        String   @id
  email     String   @unique
  fullName  String?
  createdAt DateTime @default(now())

  memberships Membership[]
}

model Membership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           Role
  tosAcceptedAt  DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
}

model Vehicle {
  id             String        @id @default(uuid())
  organizationId String
  make           String
  model          String
  year           Int
  vin            String
  licensePlate   String
  mileage        Int
  fuelLevel      Decimal       @db.Decimal(5, 2)
  dailyRate      Decimal       @db.Decimal(10, 2)
  publicDescription String?
  features       String[]
  rules          String[]
  status         VehicleStatus @default(AVAILABLE)
  location       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  images         VehicleImage[]
  documents      VehicleDocument[]
  reservations   Reservation[]
  maintenance    Maintenance[]
  damageReports  DamageReport[]
  gpsDevice      GpsDevice?
  locations      VehicleLocation[]
  availabilityBlocks VehicleAvailabilityBlock[]

  @@unique([organizationId, vin])
  @@unique([organizationId, licensePlate])
  @@index([organizationId, status])
}

model VehicleImage {
  id        String  @id @default(uuid())
  vehicleId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleAvailabilityBlock {
  id             String   @id @default(uuid())
  organizationId String
  vehicleId      String
  startsAt       DateTime
  endsAt         DateTime
  reason         String
  createdAt      DateTime @default(now())
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId, startsAt, endsAt])
}

model VehicleDocument {
  id        String   @id @default(uuid())
  vehicleId String
  kind      String
  url       String
  expiresAt DateTime?
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  email          String
  phone          String?
  address        String?
  licenseStatus  String   @default("Pending")
  customerType   String   @default("Retail")
  blacklisted    Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservations   Reservation[]
  reviews        Review[]
  rentalAgreements RentalAgreement[]

  @@unique([organizationId, email])
  @@index([organizationId, customerType])
}

model Driver {
  id             String @id @default(uuid())
  organizationId String
  customerId     String?
  fullName       String
  licenseNumber  String
  licenseState   String
  verified       Boolean @default(false)
  // Government ID uploaded at booking for host review (private Storage paths).
  idFrontPath    String?
  idFrontName    String?
  idBackPath     String?
  idBackName     String?
}

model Reservation {
  id             String            @id @default(uuid())
  organizationId String
  customerId     String
  vehicleId      String
  startsAt       DateTime
  endsAt         DateTime
  status         ReservationStatus @default(QUOTE)
  totalCents     Int
  depositCents   Int
  signedAt       DateTime?
  // Host review of the renter's identity/booking. Internal (host-created)
  // reservations are APPROVED; public bookings start PENDING_REVIEW.
  approvalStatus String            @default("APPROVED")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id])
  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id])
  payments       ReservationPayment[]
  contract       Contract?
  rentalAgreement RentalAgreement?
  damageReports  DamageReport[]

  @@index([organizationId, startsAt, endsAt])
  @@index([organizationId, status])
}

model BankAccount {
  id                      String   @id @default(uuid())
  organizationId          String
  stripeConnectAccountId  String?
  stripeExternalAccountId String?
  accountHolderName       String
  businessName            String
  accountType             String
  taxStatus               String   @default("pending")
  bankName                String?
  last4                   String?
  routingLast4            String?
  verificationStatus      String   @default("not_started")
  payoutSchedule          String   @default("automatic_daily")
  nextPayoutAt            DateTime?
  estimatedPayoutCents    Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, verificationStatus])
  @@map("bank_accounts")
}

model Payout {
  id             String   @id @default(uuid())
  organizationId String
  stripePayoutId String?
  amountCents    Int
  currency       String   @default("usd")
  status         String
  arrivalDate    DateTime?
  failureCode    String?
  failureMessage String?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@map("payouts")
}

model Transaction {
  id                String   @id @default(uuid())
  organizationId    String
  reservationId     String?
  customerName      String
  vehicleLabel      String
  grossAmountCents  Int
  platformFeeCents  Int
  processingFeeCents Int
  insuranceRevenueCents Int @default(0)
  taxesCents        Int
  netPayoutCents    Int
  status            String
  stripePaymentIntentId String?
  createdAt         DateTime @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@map("transactions")
}

model AgreementTemplate {
  id                    String   @id @default(uuid())
  organizationId        String
  businessName          String
  businessAddress       String?
  phone                 String?
  email                 String?
  terms                 String
  mileagePolicy         String
  fuelPolicy            String
  smokingPolicy         String
  petPolicy             String
  lateReturnPolicy      String
  cleaningFee           String
  damagePolicy          String
  insuranceTerms        String
  roadsideAssistance    String
  securityDeposit       String
  cancellationPolicy    String
  prohibitedUses        String
  eligibilityRequirements String?
  liabilityWaiver       String?
  disputeResolution     String?
  governingLaw          String?
  forceMajeure          String?
  platformDisclaimer    String?
  stateClauses          String
  signatureDisclosure   String
  activeVersion         Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions              AgreementVersion[]
  agreements            RentalAgreement[]

  @@index([organizationId, activeVersion])
  @@map("agreement_templates")
}

model AgreementVersion {
  id             String   @id @default(uuid())
  organizationId String
  templateId     String
  version        Int
  content        Json
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template       AgreementTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("agreement_versions")
}

model RentalAgreement {
  id             String   @id @default(uuid())
  organizationId String
  reservationId  String   @unique
  customerId     String
  templateId     String?
  version        Int
  status         String   @default("signed")
  legalName      String
  signatureMethod String
  signatureData  String
  initialsData   String?
  agreedAt       DateTime
  ipAddress      String?
  userAgent      String?
  device         String?
  location       String?
  pdfUrl         String?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservation    Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template       AgreementTemplate? @relation(fields: [templateId], references: [id])
  signatureLogs  SignatureLog[]
  certificate    SignatureCertificate?

  @@index([organizationId, status, createdAt])
  @@map("rental_agreements")
}

model SignatureLog {
  id             String   @id @default(uuid())
  organizationId String
  agreementId    String
  event          String
  ipAddress      String?
  userAgent      String?
  browser        String?
  device         String?
  location       String?
  agreementVersion Int
  signatureMethod String
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agreement      RentalAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([organizationId, agreementId, createdAt])
  @@map("signature_logs")
}

model SignatureCertificate {
  id             String   @id @default(uuid())
  agreementId    String   @unique
  certificateNumber String @unique
  signerName     String
  signedAt       DateTime
  ipAddress      String?
  userAgent      String?
  browser        String?
  device         String?
  signatureHash  String
  createdAt      DateTime @default(now())
  agreement      RentalAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@map("signature_certificates")
}

model ReservationPayment {
  id            String @id @default(uuid())
  reservationId String
  stripePaymentIntentId String?
  amountCents   Int
  kind          String
  status        String
  createdAt     DateTime @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Maintenance {
  id             String @id @default(uuid())
  organizationId String
  vehicleId      String
  kind           String
  status         String
  dueAtMileage   Int?
  dueDate        DateTime?
  costCents      Int?
  notes          String?
  vehicle        Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model DamageReport {
  id             String @id @default(uuid())
  organizationId String
  reservationId  String?
  vehicleId      String
  phase          String
  mileage        Int
  fuelLevel      Decimal @db.Decimal(5, 2)
  notes          String?
  mediaUrls      String[]
  estimateCents  Int?
  createdAt      DateTime @default(now())
  vehicle        Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reservation    Reservation? @relation(fields: [reservationId], references: [id])
}

model GpsDevice {
  id             String @id @default(uuid())
  organizationId String
  vehicleId      String @unique
  provider       String
  externalId     String
  status         String
  vehicle        Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleLocation {
  id        String @id @default(uuid())
  vehicleId String
  lat       Decimal @db.Decimal(10, 7)
  lng       Decimal @db.Decimal(10, 7)
  speedMph  Decimal? @db.Decimal(8, 2)
  fuelLevel Decimal? @db.Decimal(5, 2)
  batteryLevel Decimal? @db.Decimal(5, 2)
  recordedAt DateTime @default(now())
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model InsurancePolicy {
  id             String @id @default(uuid())
  organizationId String
  provider       String
  policyNumber   String
  startsAt       DateTime
  endsAt         DateTime
  documentUrl    String?
}

model Contract {
  id            String @id @default(uuid())
  reservationId String @unique
  pdfUrl        String?
  signatureUrl  String?
  signedAt      DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Message {
  id             String @id @default(uuid())
  organizationId String
  customerId     String?
  channel        String
  subject        String?
  customerName   String?
  customerEmail  String?
  reservationRef String?
  status         String @default("open")
  body           String
  createdAt      DateTime @default(now())

  @@index([organizationId, channel, status, createdAt])
}

model Notification {
  id             String @id @default(uuid())
  organizationId String
  userId         String?
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime @default(now())
}

model Review {
  id         String @id @default(uuid())
  customerId String
  rating     Int
  body       String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model MarketingCampaign {
  id             String @id @default(uuid())
  organizationId String
  channel        String
  name           String
  status         String
  budgetCents    Int?
  content        Json
  createdAt      DateTime @default(now())
}

model CrmContact {
  id             String @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  stage          String
  notes          String?
  createdAt      DateTime @default(now())
}

model WebsiteSetting {
  id             String @id @default(uuid())
  organizationId String @unique
  logoUrl        String?
  coverImageUrl  String?
  backgroundStyle String @default("soft")
  brandColor     String @default("#166534")
  heroTitle      String
  about          String?
  serviceArea    String?
  contactEmail   String?
  contactPhone   String?
  instagramUrl   String?
  facebookUrl    String?
  pickupInstructions String?
  cancellationPolicy String?
  depositPolicy  String?
  businessHours  String?
  trustBadges    String[]
  seoTitle       String?
  customDomain   String?
  depositFeeCents Int @default(25000)
  taxRatePct     Decimal @default(8.0) @db.Decimal(5, 3)
  platformFeePct Decimal @default(10.0) @db.Decimal(5, 3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id             String @id @default(uuid())
  name           String
  stripePriceId  String
  monthlyCents   Int
  featureLimits  Json
}

model Subscription {
  id             String @id @default(uuid())
  organizationId String @unique
  stripeSubscriptionId String
  planId         String @default("trial")
  stripePriceId  String?
  interval       String @default("monthly")
  status         String
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  latestInvoiceUrl String?
  currentPeriodEnd DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id             String @id @default(uuid())
  organizationId String
  actorUserId    String?
  action         String
  target         String
  metadata       Json?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String @id @default(uuid())
  organizationId String
  actorUserId    String?
  event          String
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Rental Insurance module
// Loosely coupled by scalar foreign keys (no enforced relations) so the module
// is self-contained. Table names map to the product spec's snake_case names.
// ============================================================================

enum InsuranceSelectionType {
  THIRD_PARTY   // purchased coverage from a provider (RentalCover/Allianz/Bonzah)
  CUSTOMER_OWN  // customer uploaded proof of their own policy
  DECLINED      // declined coverage (only when the org allows it)
}

enum InsuranceCoverageStatus {
  PENDING_SELECTION   // booking started, no choice yet
  ACTIVE              // third-party coverage purchased & active
  PENDING_UPLOAD      // own-insurance chosen, awaiting documents
  PENDING_REVIEW      // documents uploaded, awaiting manual approval
  APPROVED            // own insurance approved
  REJECTED            // own insurance rejected
  MORE_INFO_REQUIRED  // owner asked for additional documents
  DECLINED            // customer declined coverage
}

enum InsuranceVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

enum InsuranceDocumentKind {
  CARD_FRONT
  CARD_BACK
  DECLARATION_PAGE
  RECEIPT
  OTHER
}

/// Per-organization configuration of which providers are offered.
model InsuranceProvider {
  id             String   @id @default(uuid())
  organizationId String
  key            String   // "rentalcover" | "allianz" | "bonzah"
  name           String
  enabled        Boolean  @default(true)
  config         Json?    // future: API credentials / commission settings
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("insurance_providers")
}

/// A purchased third-party policy instance (the result of buying a quoted plan).
model InsurancePurchase {
  id              String   @id @default(uuid())
  organizationId  String
  reservationId   String?
  customerId      String?
  providerKey     String   // "rentalcover" | "allianz" | "bonzah"
  planId          String   // provider plan identifier
  planName        String
  coverageSummary String
  coverageLimits  Json?    // { liability, collision, ... } in cents
  deductibleCents Int      @default(0)
  dailyPriceCents Int
  totalPriceCents Int
  policyNumber    String?
  externalRef     String?  // provider-side policy id once integrated
  status          InsuranceCoverageStatus @default(ACTIVE)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([reservationId])
  @@map("insurance_policies")
}

/// A customer's submission of their own existing insurance for review.
model CustomerInsuranceUpload {
  id               String   @id @default(uuid())
  organizationId   String
  customerId       String?
  reservationId    String?
  insuranceCompany String
  policyNumber     String
  policyHolderName String
  expirationDate   DateTime?
  additionalNotes  String?
  status           InsuranceVerificationStatus @default(PENDING)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId])
  @@index([reservationId])
  @@map("customer_insurance_uploads")
}

/// A stored document (insurance card front/back, declaration page, receipt).
model InsuranceDocument {
  id           String   @id @default(uuid())
  uploadId     String?  // CustomerInsuranceUpload.id
  purchaseId   String?  // InsurancePurchase.id (e.g. receipt)
  kind         InsuranceDocumentKind
  storagePath  String   // Supabase Storage object path (private bucket)
  fileName     String?
  contentType  String?
  createdAt    DateTime @default(now())

  @@index([uploadId])
  @@map("insurance_documents")
}

/// Links a reservation to its insurance choice and tracks coverage status.
model ReservationInsurance {
  id             String   @id @default(uuid())
  organizationId String
  reservationId  String   @unique
  customerId     String?
  selectionType  InsuranceSelectionType
  status         InsuranceCoverageStatus @default(PENDING_SELECTION)
  providerKey    String?  // when THIRD_PARTY
  purchaseId     String?  // InsurancePurchase.id
  uploadId       String?  // CustomerInsuranceUpload.id
  coverageCostCents Int   @default(0)
  depositCents   Int      @default(0) // deposit applied for this selection
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
  @@map("reservation_insurance")
}

/// Audit trail of verification decisions on uploaded customer insurance.
model InsuranceVerification {
  id            String   @id @default(uuid())
  organizationId String
  uploadId      String
  reviewerId    String?  // User.id of the owner/staff who reviewed
  status        InsuranceVerificationStatus
  notes         String?
  createdAt     DateTime @default(now())

  @@index([organizationId])
  @@index([uploadId])
  @@map("insurance_verifications")
}

/// Per-organization insurance policy/configuration set by the business owner.
model InsuranceSetting {
  id                          String   @id @default(uuid())
  organizationId              String   @unique
  requireInsurance            Boolean  @default(false)
  allowOwnInsurance           Boolean  @default(true)
  allowDecline                Boolean  @default(true)
  manualApproval              Boolean  @default(true)
  enabledProviders            String[] @default(["rentalcover", "allianz", "bonzah"])
  minLiabilityCents           Int      @default(5000000)
  requiredCoverageLimitsCents Int      @default(3500000)
  customTerms                 String?
  depositThirdPartyCents      Int      @default(20000)
  depositOwnInsuranceCents    Int      @default(35000)
  depositDeclinedCents        Int      @default(75000)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("insurance_settings")
}
